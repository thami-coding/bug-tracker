pipeline {
    agent any

    stages {
        stage('Unit Test - Backend') {
            agent {
                docker{
                    image 'snakee/golang-junit:1.21'
                    reuseNode true
                }
            }
            environment {
                GOCACHE = '/tmp/go-cache'
                GOMODCACHE = '/tmp/go-mod-cache'
                }
            steps {
               dir('bugtracker-backend'){
                sh 'go test -v ./...'
               }
            }
        }

        stage('Unit Tests - Frontend'){
            agent{
                docker{
                    image: "mode:20-alpine"
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-frontend'){
                    sh '''
                    npm ci
                    npm test
                    '''
                }
            }
        }
    }
}